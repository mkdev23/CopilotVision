# CVP Azure Deployment — environment variables
# Copy to .env.deploy and source before running deploy.sh:
#   cp .env.deploy.example .env.deploy && nano .env.deploy
#   source .env.deploy && bash deploy.sh

# ── Azure Vision (CVP-demo resource) ─────────────────────────────────────────
# Portal: CVP-demo → Keys and Endpoint
export AZURE_VISION_ENDPOINT="https://CVP-demo.cognitiveservices.azure.com/"
export AZURE_VISION_KEY="YOUR_AZURE_VISION_KEY"

# ── MCP Server auth ───────────────────────────────────────────────────────────
# Any secret string — set the same value in Android Settings → MCP Bearer Token
export MCP_BEARER_TOKEN="YOUR_MCP_BEARER_TOKEN_ANY_SECRET_STRING"

# ── Optional: gateway bearer token (leave blank to allow unauthenticated) ─────
export GATEWAY_BEARER_TOKEN="YOUR_GATEWAY_BEARER_TOKEN_ANY_SECRET_STRING"

# ── Image tag (default: latest) ───────────────────────────────────────────────
export IMAGE_TAG="latest"
