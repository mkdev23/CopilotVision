# CVP Agent Service — environment variables
# Copy to .env and fill in values before running agent.py

# Azure AI Foundry project endpoint
# Found in: Foundry portal → your project → Overview → Endpoint
FOUNDRY_PROJECT_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/

# Foundry / Azure OpenAI API key (same key as Android Settings → Azure OpenAI API Key)
FOUNDRY_API_KEY=YOUR_AZURE_OPENAI_API_KEY

# CVP MCP Server URL (deployed to Azure Container Apps)
# Local dev: http://localhost:8001/mcp
MCP_SERVER_URL=https://cvp-mcp-server.orangeflower-68897f93.eastus2.azurecontainerapps.io/mcp

# Bearer token for MCP server auth (must match MCP_BEARER_TOKEN on the server)
MCP_BEARER_TOKEN=YOUR_MCP_BEARER_TOKEN

# (Optional) existing agent ID — if set, --update will modify this agent
AGENT_ID=

# (Optional) default Teams chat ID for the draft_message tool
TEAMS_DEFAULT_CHAT_ID=
